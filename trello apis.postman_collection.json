  "item": [
    {
      "name": "Create board",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Parse response\r",
              "const jsonData = pm.response.json();\r",
              "\r",
              "// 1. Status check\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// 2. Basic fields validation\r",
              "pm.test(\"Board basic info is correct\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"id\");\r",
              "    pm.expect(jsonData).to.have.property(\"name\");\r",
              "    pm.expect(jsonData).to.have.property(\"closed\");\r",
              "    pm.expect(jsonData).to.have.property(\"url\");\r",
              "});\r",
              "\r",
              "// 3. URL format validation\r",
              "pm.test(\"URL is valid Trello board link\", function () {\r",
              "    pm.expect(jsonData.url).to.match(/^https:\\/\\/trello\\.com\\/b\\/.+/);\r",
              "});\r",
              "\r",
              "// 4. Prefs object validation\r",
              "pm.test(\"Prefs object validation\", function () {\r",
              "    pm.expect(jsonData.prefs).to.be.an(\"object\");\r",
              "\r",
              "    pm.expect(jsonData.prefs.permissionLevel).to.eql(\"private\");\r",
              "    pm.expect(jsonData.prefs.voting).to.eql(\"disabled\");\r",
              "    pm.expect(jsonData.prefs.comments).to.eql(\"members\");\r",
              "    pm.expect(jsonData.prefs.invitations).to.eql(\"members\");\r",
              "    pm.expect(jsonData.prefs.selfJoin).to.be.true;\r",
              "});\r",
              "\r",
              "// 5. Background settings\r",
              "pm.test(\"Background settings are correct\", function () {\r",
              "    pm.expect(jsonData.prefs.background).to.eql(\"blue\");\r",
              "    pm.expect(jsonData.prefs.backgroundColor).to.eql(\"#0079BF\");\r",
              "});\r",
              "\r",
              "// 6. Switcher views validation\r",
              "pm.test(\"Switcher views contain Board and Table\", function () {\r",
              "    const views = jsonData.prefs.switcherViews;\r",
              "\r",
              "    const viewTypes = views.map(v => v.viewType);\r",
              "\r",
              "    pm.expect(viewTypes).to.include(\"Board\");\r",
              "    pm.expect(viewTypes).to.include(\"Table\");\r",
              "});\r",
              "\r",
              "// 7. Label names exist\r",
              "pm.test(\"Label names object exists\", function () {\r",
              "    pm.expect(jsonData.labelNames).to.be.an(\"object\");\r",
              "});\r",
              "\r",
              "// 8. Permission capabilities\r",
              "pm.test(\"Board permissions flags\", function () {\r",
              "    pm.expect(jsonData.prefs.canBePrivate).to.be.true;\r",
              "    pm.expect(jsonData.prefs.canInvite).to.be.true;\r",
              "});\r",
              "pm.collectionVariables.set(\"BoardId\", jsonData.id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
